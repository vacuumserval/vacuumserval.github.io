              RowBox[{"Fst", "[", 
               RowBox[{"nst", ",", "\[Epsilon]"}], "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"ntr2", "-", "nst"}], ")"}]}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ntr2", ",", 
          RowBox[{"-", "0.1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"nst", ",", 
          RowBox[{"-", "0.0"}]}], "}"}]}], "]"}]}], "]"}]}]}], 

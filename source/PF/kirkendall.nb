Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"nsq", "[", 
    RowBox[{"n_", ",", "A_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", "x", "]"}], "+", 
       RowBox[{"Cos", "[", "y", "]"}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ntr", "[", 
    RowBox[{"n_", ",", "A_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{
          FractionBox[
           SqrtBox["3"], "2"], "x"}], "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{
          FractionBox["1", "2"], "y"}], "]"}]}], "+", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Cos", "[", "y", "]"}]}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nst", "[", 
    RowBox[{"n_", ",", "A_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{"Cos", "[", "x", "]"}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nlq", "[", 
    RowBox[{"n_", ",", "A_", ",", "x_", ",", "y_"}], "]"}], "=", "n"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{

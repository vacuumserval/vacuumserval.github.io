Cell["The Integrand", "Subsection",
 CellChangeTimes->{{3.914313347464096*^9, 
  3.9143133514235334`*^9}},ExpressionUUID->"d443d5c6-c541-4d01-af39-\
871b9b474c88"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"gsq", "[", 
    RowBox[{
    "n_", ",", "\[Psi]_", ",", "A_", ",", "B0l_", ",", "B0x_", ",", "B2l_", 
     ",", "t_", ",", "v_", ",", "\[Gamma]_", ",", "\[Omega]_", ",", "\[Mu]_", 
     ",", "x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"nsq", "[", 
       RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], "2"], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"B0l", "-", "B0x"}], ")"}], "*", 
        RowBox[{"nsq", "[", 
         RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}]}], "+", 
       RowBox[{"B2l", "*", 
        SuperscriptBox["\[Psi]", "2"], "*", 
        RowBox[{"nsq", "[", 
         RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}]}], "+", 
       RowBox[{"B0x", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"nsq", "[", 
           RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], "+", 
          RowBox[{"2", "*", 
           RowBox[{"Laplacian", "[", 
            RowBox[{
             RowBox[{"nsq", "[", 
              RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "+", 
          RowBox[{"Laplacian", "[", 
           RowBox[{
            RowBox[{"Laplacian", "[", 
             RowBox[{
              RowBox[{"nsq", "[", 
               RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ")"}]}]}], ")"}]}], 
    "-", 
    RowBox[{
     FractionBox["t", "3"], "*", 
     SuperscriptBox[
      RowBox[{"nsq", "[", 
       RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], "3"]}], "+", 
    RowBox[{
     FractionBox["v", "4"], "*", 
     SuperscriptBox[
      RowBox[{"nsq", "[", 
       RowBox[{"n", ",", "A", ",", "x", ",", "y"}], "]"}], "4"]}], "+", 
    RowBox[{"\[Gamma]", "*", "\[Psi]"}], "+", 
    RowBox[{
     FractionBox["\[Omega]", "2"], "*", 
     SuperscriptBox["\[Psi]", "2"]}], "+", 
    RowBox[{
     FractionBox["\[Mu]", "4"], "*", 
     SuperscriptBox["\[Psi]", "4"]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gtr", "[", 

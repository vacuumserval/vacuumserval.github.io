Cell[CellGroupData[{

Cell["The Simplest PFC Model", "Section",
 CellChangeTimes->{{3.9143125477769127`*^9, 
  3.91431260053379*^9}},ExpressionUUID->"76c66440-81ee-4b9e-8346-\
ef1f28e6ab45"],

Cell[TextData[{
 "F(n)=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{"\[Epsilon]", 
      FractionBox[
       SuperscriptBox["n", "2"], "2"]}]}], "+", 
    FractionBox[
     SuperscriptBox["n", "4"], "4"], "+", 
    RowBox[{
     FractionBox["n", "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["\[Del]", "2"]}], ")"}], "2"], "n", 
     RowBox[{"\[DifferentialD]", "x"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2926eddc-f557-40ec-86de-967ba8f5b632"],
 " "
}], "Text",
 CellChangeTimes->{{3.9143126095254955`*^9, 3.914312799215886*^9}, {
  3.9143133107197227`*^9, 
  3.914313340452075*^9}},ExpressionUUID->"67166907-dd8f-46b3-9324-\
609c6fa5e2bb"],

Cell[CellGroupData[{

Cell["The Integrand", "Subsection",
 CellChangeTimes->{{3.914313347464096*^9, 
  3.9143133514235334`*^9}},ExpressionUUID->"d443d5c6-c541-4d01-af39-\
871b9b474c88"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"gsq", "[", 
    RowBox[{
    "n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_", ",", "x_", ",", "y_"}], 
    "]"}], "=", 
   RowBox[{
    RowBox[{"\[Epsilon]", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"nsq", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
      "2"]}], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"nsq", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "4"], 
     "4"], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"nsq", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
     "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"nsq", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "+", 
       RowBox[{"2", "*", 
        RowBox[{"Laplacian", "[", 
         RowBox[{
          RowBox[{"nsq", "[", 
           RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "+", 
       RowBox[{"Laplacian", "[", 
        RowBox[{
         RowBox[{"Laplacian", "[", 
          RowBox[{
           RowBox[{"nsq", "[", 
            RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gtr", "[", 
    RowBox[{
    "n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_", ",", "x_", ",", "y_"}], 
    "]"}], "=", 
   RowBox[{
    RowBox[{"\[Epsilon]", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"ntr", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
      "2"]}], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"ntr", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "4"], 
     "4"], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"ntr", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
     "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ntr", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "+", 
       RowBox[{"2", "*", 
        RowBox[{"Laplacian", "[", 
         RowBox[{
          RowBox[{"ntr", "[", 
           RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "+", 
       RowBox[{"Laplacian", "[", 
        RowBox[{
         RowBox[{"Laplacian", "[", 
          RowBox[{
           RowBox[{"ntr", "[", 
            RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gst", "[", 
    RowBox[{
    "n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_", ",", "x_", ",", "y_"}], 
    "]"}], "=", 
   RowBox[{
    RowBox[{"\[Epsilon]", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"nst", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
      "2"]}], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"nst", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "4"], 
     "4"], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"nst", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
     "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"nst", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "+", 
       RowBox[{"2", "*", 
        RowBox[{"Laplacian", "[", 
         RowBox[{
          RowBox[{"nst", "[", 
           RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "+", 
       RowBox[{"Laplacian", "[", 
        RowBox[{
         RowBox[{"Laplacian", "[", 
          RowBox[{
           RowBox[{"nst", "[", 
            RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"glq", "[", 
    RowBox[{
    "n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_", ",", "x_", ",", "y_"}], 
    "]"}], "=", 
   RowBox[{
    RowBox[{"\[Epsilon]", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"nlq", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
      "2"]}], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"nlq", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "4"], 
     "4"], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"nlq", "[", 
       RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "2"], 
     "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"nlq", "[", 
        RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], "+", 
       RowBox[{"2", "*", 
        RowBox[{"Laplacian", "[", 
         RowBox[{
          RowBox[{"nlq", "[", 
           RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "+", 
       RowBox[{"Laplacian", "[", 
        RowBox[{
         RowBox[{"Laplacian", "[", 
          RowBox[{
           RowBox[{"nlq", "[", 
            RowBox[{"n", ",", "A", ",", "a", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ")"}]}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.914312836036882*^9, 3.9143131020207443`*^9}, {
  3.9143131676754484`*^9, 3.914313291493724*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"b1fae02a-67ab-4157-8422-80538f2d6e38"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Free Energy per Area (free energy density)", "Subsection",
 CellChangeTimes->{{3.9143133576801853`*^9, 
  3.9143133800786924`*^9}},ExpressionUUID->"79681b90-05f6-4cd1-bce1-\
543f60c9964c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fsq", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"gsq", "[", 
         RowBox[{
         "n", ",", "A", ",", "a", ",", "\[Epsilon]", ",", "x", ",", "y"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "a"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "a"}], "}"}]}], "]"}], "/", 
    RowBox[{"(", 
     SuperscriptBox["a", "2"], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ftr", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "\[Epsilon]_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"gtr", "[", 
         RowBox[{
         "n", ",", "A", ",", "a", ",", "\[Epsilon]", ",", "x", ",", "y"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", 
          FractionBox[
           RowBox[{"2", " ", "a"}], 
           SqrtBox["3"]]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", 
        RowBox[{"2", "a"}]}], "}"}]}], "]"}], "/", 
    RowBox[{"(", 
     FractionBox[
      RowBox[{"4", " ", 
       SuperscriptBox["a", "2"]}], 

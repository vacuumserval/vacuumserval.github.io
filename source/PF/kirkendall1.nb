Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"calPhad", "[", "\[Psi]_", "]"}], ":=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"nl", ",", " ", "ns"}], "}"}], "/.", 
    RowBox[{"Join", "[", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Flq", "[", 
             RowBox[{"nl", ",", "\[Psi]"}], "]"}], ",", "nlq"}], "]"}], 
          "\[Equal]", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Ftr", "[", 
             RowBox[{"ns", ",", "\[Psi]"}], "]"}], ",", "ns"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Flq", "[", 
             RowBox[{"nl", ",", "\[Psi]"}], "]"}], ",", "nl"}], "]"}], 
          "\[Equal]", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Flq", "[", 
              RowBox[{"nl", ",", "\[Psi]"}], "]"}], "-", 
             RowBox[{"Ftr", "[", 
              RowBox[{"ns", ",", "\[Psi]"}], "]"}]}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"nl", "-", "ns"}], ")"}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"nl", ",", 
         RowBox[{"-", "0.2"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"ns", ",", 
         RowBox[{"-", "0.1"}]}], "}"}]}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Transpose", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"calPhad", "[", "#", "]"}], "&"}], "/@", 
     RowBox[{"Range", "[", 

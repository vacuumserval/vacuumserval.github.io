       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Fst", "[", 
          RowBox[{"nst", ",", 
           SubscriptBox["\[Epsilon]", "eg"]}], "]"}], ",", "nst"}], "]"}], 
       "\[Equal]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"calPhad", "[", "\[Epsilon]_", "]"}], ":=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"nlq", ",", " ", "ntr1", ",", " ", "ntr2", ",", " ", "nst"}], 
     "}"}], "/.", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Flq", "[", 
              RowBox[{"nlq", ",", "\[Epsilon]"}], "]"}], ",", "nlq"}], "]"}], 
           "\[Equal]", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Ftr", "[", 
              RowBox[{"ntr1", ",", "\[Epsilon]"}], "]"}], ",", "ntr1"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Flq", "[", 
              RowBox[{"nlq", ",", "\[Epsilon]"}], "]"}], ",", "nlq"}], "]"}], 
           "\[Equal]", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Flq", "[", 
               RowBox[{"nlq", ",", "\[Epsilon]"}], "]"}], "-", 
              RowBox[{"Ftr", "[", 
               RowBox[{"ntr1", ",", "\[Epsilon]"}], "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"nlq", "-", "ntr1"}], ")"}]}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"nlq", ",", 
          RowBox[{"-", "0.5"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ntr1", ",", 
          RowBox[{"-", "0.3"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Ftr", "[", 
              RowBox[{"ntr2", ",", "\[Epsilon]"}], "]"}], ",", "ntr2"}], 
            "]"}], "\[Equal]", 
           RowBox[{"D", "[", 

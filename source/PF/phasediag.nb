66360353c5f3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"nsq", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"2", "\[Pi]"}], "a"], "x"}], "]"}], "+", 
       RowBox[{"Cos", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"2", "\[Pi]"}], "a"], "y"}], "]"}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ntr", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{
          FractionBox[
           RowBox[{
            SqrtBox["3"], "\[Pi]"}], "a"], "x"}], "]"}], 
        RowBox[{"Cos", "[", 
         RowBox[{
          FractionBox["\[Pi]", "a"], "y"}], "]"}]}], "+", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Cos", "[", 
         RowBox[{
          FractionBox[
           RowBox[{"2", "\[Pi]"}], "a"], "y"}], "]"}]}]}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nst", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"n", "+", 
    RowBox[{"A", "*", 
     RowBox[{"(", 
      RowBox[{"Cos", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"2", "\[Pi]"}], "a"], "x"}], "]"}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nlq", "[", 
    RowBox[{"n_", ",", "A_", ",", "a_", ",", "x_", ",", "y_"}], "]"}], "=", 
   "n"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"nsq", "[", 
    RowBox[{"0.0", ",", "1.0", ",", 
     RowBox[{"2", "\[Pi]"}], ",", "x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "10"}], "\[Pi]"}], ",", 
     RowBox[{"10", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{
      RowBox[{"-", "10"}], "\[Pi]"}], ",", 
     RowBox[{"10", "\[Pi]"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"ntr", "[", 
    RowBox[{"0.0", ",", "1.0", ",", 
     RowBox[{"2", "\[Pi]"}], ",", "x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "10"}], "\[Pi]"}], ",", 
     RowBox[{"10", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{
      RowBox[{"-", "10"}], "\[Pi]"}], ",", 
     RowBox[{"10", "\[Pi]"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"nst", "[", 

      RowBox[{"-", "10"}], "\[Pi]"}], ",", 
     RowBox[{"10", "\[Pi]"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"nlq", "[", 

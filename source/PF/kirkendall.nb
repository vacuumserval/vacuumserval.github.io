Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"calPhad", "[", "\[Psi]_", "]"}], ":=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"nlq", ",", " ", "ntr1", ",", " ", "ntr2", ",", " ", "nst"}], 
     "}"}], "/.", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Flq", "[", 
              RowBox[{
              "nlq", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "nlq"}], "]"}], "\[Equal]", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Ftr", "[", 
              RowBox[{
              "ntr1", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "ntr1"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Flq", "[", 
              RowBox[{
              "nlq", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "nlq"}], "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Flq", "[", 
               RowBox[{
               "nlq", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
                "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
                "\[Mu]"}], "]"}], "-", 
              RowBox[{"Ftr", "[", 
               RowBox[{
               "ntr1", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",",
                 "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
                "\[Mu]"}], "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"nlq", "-", "ntr1"}], ")"}]}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"nlq", ",", 
          RowBox[{"-", "0.3"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ntr1", ",", 
          RowBox[{"-", "0.1"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Ftr", "[", 
              RowBox[{
              "ntr2", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "ntr2"}], "]"}], "\[Equal]", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Fst", "[", 
              RowBox[{
              "nst", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "nst"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Ftr", "[", 
              RowBox[{
              "ntr2", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
               "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
               "\[Mu]"}], "]"}], ",", "ntr2"}], "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Ftr", "[", 
               RowBox[{
               "ntr2", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",",
                 "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
                "\[Mu]"}], "]"}], "-", 
              RowBox[{"Fst", "[", 
               RowBox[{
               "nst", ",", "\[Psi]", ",", "B0l", ",", "B0x", ",", "B2l", ",", 
                "t", ",", "v", ",", "\[Gamma]", ",", "\[Omega]", ",", 
                "\[Mu]"}], "]"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"ntr2", "-", "nst"}], ")"}]}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ntr2", ",", 
          RowBox[{"-", "0.1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"nst", ",", "0.1"}], "}"}]}], "]"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", " ", "=", " ", 
   RowBox[{"Transpose", "[", 

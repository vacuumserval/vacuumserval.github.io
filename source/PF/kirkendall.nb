Cell[CellGroupData[{

Cell["The Kirkendall PFC Model", "Section",
 CellChangeTimes->{{3.9143125477769127`*^9, 3.91431260053379*^9}, {
  3.914485110075733*^9, 
  3.9144851129448996`*^9}},ExpressionUUID->"76c66440-81ee-4b9e-8346-\
ef1f28e6ab45"],

Cell[TextData[{
 "F(n)=",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox["n", "2"], "\[CapitalLambda]n"}]}], "-", 
    RowBox[{
     FractionBox["t", "3"], 
     SuperscriptBox["n", "3"]}], "+", 
    RowBox[{
     FractionBox["v", "4"], 
     SuperscriptBox["n", "4"]}], "+", "\[Gamma]\[Psi]", "+", 
    RowBox[{
     FractionBox["\[Omega]", "2"], 
     SuperscriptBox["\[Psi]", "2"]}], "+", 
    RowBox[{
     FractionBox["\[Mu]", "4"], 
     SuperscriptBox["\[Psi]", "4"]}], "+", 
    RowBox[{
     FractionBox["\[Kappa]", "2"], 
     RowBox[{"\[Del]", 
      SuperscriptBox["\[Psi]", "2"]}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], TraditionalForm]],ExpressionUUID->
  "2926eddc-f557-40ec-86de-967ba8f5b632"],
 "\nwhere  \[CapitalLambda]=(B0l-B0x)+B2l",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Psi]", "2"], TraditionalForm]],ExpressionUUID->
  "ccbb3b44-6137-45c6-bf15-bf2ffe40819f"],
 "+B0x",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["\[Del]", "2"]}], ")"}], "2"], TraditionalForm]],
  ExpressionUUID->"ff7cde9f-c28b-467e-82e5-038af47ab582"]
}], "Text",
 CellChangeTimes->{{3.9143126095254955`*^9, 3.914312799215886*^9}, {
  3.9143133107197227`*^9, 3.914313340452075*^9}, {3.914487762561592*^9, 
  3.914488016354529*^9}, {3.9144880859714575`*^9, 
  3.914488096489194*^9}},ExpressionUUID->"67166907-dd8f-46b3-9324-\
609c6fa5e2bb"],


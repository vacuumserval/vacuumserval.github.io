    RowBox[{"0.0", ",", "1.0", ",", "x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "10"}], "\[Pi]"}], ",", 

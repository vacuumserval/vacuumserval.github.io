 RowBox[{"comtansol", "=", 
  RowBox[{"FindRoot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Ftr", "[", 
          RowBox[{"ntr", ",", 
           SubscriptBox["\[Epsilon]", "eg"]}], "]"}], ",", "ntr"}], "]"}], 
       "\[Equal]", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Fst", "[", 
          RowBox[{"nst", ",", 
           SubscriptBox["\[Epsilon]", "eg"]}], "]"}], ",", "nst"}], "]"}]}], 
      ",", 
